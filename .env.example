# --- Claude / Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
# Modelo por defecto. Para alto volumen/menor costo: claude-sonnet-4-6 o claude-haiku-4-5
CLAUDE_MODEL=claude-opus-4-8

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=intergranel-verify
# App Secret de la app de Meta para validar la firma X-Hub-Signature-256.
# Si se deja vacío, la verificación de firma se omite (modo desarrollo).
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0
# Plantilla aprobada para notificaciones proactivas (opcional).
# Si se deja vacío, las notificaciones salen como texto (solo válido dentro de la ventana de 24h).
WHATSAPP_ORDER_TEMPLATE=
WHATSAPP_TEMPLATE_LANGUAGE=es_MX

# --- ERP / API externo de órdenes ---
# Si se deja vacío, se usa un ERP simulado en memoria (modo desarrollo).
# Debe incluir el prefijo de la API, p. ej. https://erp-intergranel.example.com/api/v1
ERP_BASE_URL=
ERP_API_KEY=
# Si se define, la API key viaja en este header (p. ej. X-Bot-Api-Key).
# Si se deja vacío, se envía como Authorization: Bearer <ERP_API_KEY>.
ERP_API_KEY_HEADER=X-Bot-Api-Key

# --- Seguridad del webhook de notificaciones del ERP ---
ERP_WEBHOOK_SECRET=

# --- Persistencia del historial de conversación ---
# Si se deja vacío, el historial se guarda en memoria (se pierde al reiniciar).
# Ej.: redis://default:password@host:6379/0
REDIS_URL=
HISTORY_TTL_SECONDS=604800
# TTL para deduplicar webhooks repetidos por message.id (idempotencia).
DEDUP_TTL_SECONDS=86400

# --- Identidad ---
COMPANY_NAME=Intergranel

# --- Agente de Compras ---
# Teléfonos autorizados a usar el agente de Compras, en formato internacional
# sin '+', separados por comas. Si se deja vacío, no se aplica restricción
# (modo desarrollo). Ej.: 5215512345678,5215598765432
COMPRAS_PHONES_ALLOWED=

# --- Alertas de inventario ---
# Teléfonos del equipo que reciben las alertas proactivas de inventario
# (webhook POST /webhooks/erp/inventory-alert), separados por comas. Si se deja
# vacío, las alertas solo se registran en el bus y el log (no se envían).
INVENTORY_ALERT_PHONES=
